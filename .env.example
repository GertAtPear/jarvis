# ──────────────────────────────────────────────────────────────────────────────
# Mediahost AI Platform — Environment Template
# Copy to .env and fill in all values before starting the stack.
# ──────────────────────────────────────────────────────────────────────────────

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=ai.example.com

# ── Platform PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_postgres

# ── Platform Redis ────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis

# ── Infisical Vault ───────────────────────────────────────────────────────────
INFISICAL_DB_PASSWORD=change_me_infisical_db
INFISICAL_REDIS_PASSWORD=change_me_infisical_redis
# Generate with: openssl rand -hex 32
INFISICAL_ENCRYPTION_KEY=
# Generate with: openssl rand -base64 32
INFISICAL_AUTH_SECRET=

# ── Infisical Machine Identity (filled after vault setup) ────────────────────
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=

# ── LLM Providers (stored in Infisical; set here for local dev only) ─────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Andrew Agent ─────────────────────────────────────────────────────────────
ANDREW_DISCOVERY_INTERVAL_HOURS=4
ANDREW_SSH_TIMEOUT_SECONDS=10
ANDREW_SSH_MAX_PARALLEL_CONNECTIONS=5

# ── Eve Agent ─────────────────────────────────────────────────────────────────
EVE_TIMEZONE=Africa/Johannesburg
EVE_MORNING_BRIEFING_ON_FIRST_OPEN=true

# ── Browser Agent ─────────────────────────────────────────────────────────────
BROWSER_MAX_CONCURRENT_SESSIONS=3
BROWSER_DEFAULT_TIMEOUT_SECONDS=30
BROWSER_HEADLESS=true
