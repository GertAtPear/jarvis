-- ─── {{AgentName}} schema ──────────────────────────────────────────────────────

CREATE SCHEMA IF NOT EXISTS {{SchemaName}};

-- Session storage (one row per user conversation session)
CREATE TABLE IF NOT EXISTS {{SchemaName}}.sessions (
    id              UUID         PRIMARY KEY DEFAULT gen_random_uuid(),
    session_id      VARCHAR(255) NOT NULL UNIQUE,
    agent_name      VARCHAR(100) NOT NULL DEFAULT '{{AgentNameLower}}',
    created_at      TIMESTAMPTZ  DEFAULT NOW(),
    last_active_at  TIMESTAMPTZ  DEFAULT NOW()
);

-- Conversation history
CREATE TABLE IF NOT EXISTS {{SchemaName}}.conversations (
    id          UUID         PRIMARY KEY DEFAULT gen_random_uuid(),
    session_id  VARCHAR(255) NOT NULL,
    role        VARCHAR(20)  NOT NULL,  -- user | assistant
    content     TEXT         NOT NULL,
    created_at  TIMESTAMPTZ  DEFAULT NOW()
);
CREATE INDEX ON {{SchemaName}}.conversations(session_id, created_at);

-- Permanent memory facts (key/value pairs persisted across sessions)
CREATE TABLE IF NOT EXISTS {{SchemaName}}.memory (
    id          UUID         PRIMARY KEY DEFAULT gen_random_uuid(),
    key         VARCHAR(255) NOT NULL UNIQUE,
    value       TEXT         NOT NULL,
    updated_at  TIMESTAMPTZ  DEFAULT NOW()
);

