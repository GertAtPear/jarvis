<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>{{AgentName}}.Agent</RootNamespace>
    <AssemblyName>{{AgentName}}.Agent</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.4" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.Http.Polly" Version="10.0.5" />
    <PackageReference Include="Polly" Version="8.6.6" />
    <PackageReference Include="Serilog.AspNetCore" Version="10.0.0" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.1.1" />
    <PackageReference Include="Serilog.Sinks.File" Version="7.0.0" />
    {{#if HasJobs}}
    <PackageReference Include="Quartz" Version="3.16.1" />
    <PackageReference Include="Quartz.AspNetCore" Version="3.16.1" />
    {{/if}}
    {{#if HasSsh}}
    <PackageReference Include="Renci.SshNet" Version="2024.2.0" />
    {{/if}}
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Mediahost.Agents\Mediahost.Agents.csproj" />
    <ProjectReference Include="..\Mediahost.Tools\Mediahost.Tools.csproj" />
    <ProjectReference Include="..\Mediahost.Auth\Mediahost.Auth.csproj" />
  </ItemGroup>

</Project>
